.mx_ColorPicker {
    padding: 24px;

    .mx_ColorPicker_tabs {
        display: flex;
        gap: 0;
        border-bottom: 1px solid $quaternary-content;
        margin-bottom: 16px;
    }

    .mx_ColorPicker_tab {
        flex: 1;
        padding: 8px 16px;
        border: none;
        background: transparent;
        cursor: pointer;
        color: $tertiary-content;
        font-size: 14px;
        font-weight: 500;
        border-bottom: 2px solid transparent;

        &_active {
            color: $accent;
            border-bottom-color: $accent;
        }
    }

    .mx_ColorPicker_content {
        min-height: 200px;
    }

    .mx_ColorPicker_presets {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin-bottom: 16px;
    }

    .mx_ColorPicker_swatch {
        width: 28px;
        height: 28px;
        border: 1px solid $quinary-content;
        border-radius: 4px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
    }

    .mx_ColorPicker_checkmark {
        color: white;
        text-shadow: 0 0 2px rgba(0, 0, 0, 0.8);
        font-size: 14px;
    }

    .mx_ColorPicker_custom {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 16px;

        label {
            font-size: 13px;
            color: $secondary-content;
        }

        input[type="color"] {
            width: 40px;
            height: 28px;
            border: 1px solid $quinary-content;
            border-radius: 4px;
            cursor: pointer;
            padding: 0;
        }
    }

    .mx_ColorPicker_directions {
        margin-bottom: 16px;

        label {
            display: block;
            font-size: 13px;
            color: $secondary-content;
            margin-bottom: 8px;
        }
    }

    .mx_ColorPicker_direction_buttons {
        display: flex;
        gap: 4px;
    }

    .mx_ColorPicker_direction_btn {
        width: 36px;
        height: 36px;
        border: 1px solid $quinary-content;
        border-radius: 4px;
        cursor: pointer;
        background: transparent;
        font-size: 16px;
        display: flex;
        align-items: center;
        justify-content: center;

        &_active {
            background: $accent;
            border-color: $accent;
            color: #fff;
        }
    }

    .mx_ColorPicker_stops {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .mx_ColorPicker_stop {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 4px 0;

        input[type="color"] {
            width: 32px;
            height: 24px;
            border: 1px solid $quinary-content;
            border-radius: 4px;
            cursor: pointer;
            padding: 0;
        }
    }

    .mx_ColorPicker_stop_position_label {
        font-size: 12px;
        color: $secondary-content;
    }

    .mx_ColorPicker_stop_position {
        flex: 1;
        max-width: 100px;
    }

    .mx_ColorPicker_position_value {
        font-size: 12px;
        color: $tertiary-content;
        min-width: 32px;
    }

    .mx_ColorPicker_remove_stop {
        border: none;
        background: transparent;
        cursor: pointer;
        color: $tertiary-content;
        font-size: 12px;
        padding: 2px 4px;
    }

    .mx_ColorPicker_add_stop {
        border: 1px dashed $quinary-content;
        background: transparent;
        cursor: pointer;
        padding: 6px 12px;
        border-radius: 4px;
        color: $accent;
        font-size: 13px;
        width: fit-content;
    }
}
